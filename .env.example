# Copy to .env and adjust. Every value has a sensible default in code, so .env
# is optional — it mainly exists to override ROIs and the model path.

# ===================== SCREEN CAPTURE =====================
GAME_MONITOR_TOP=0
GAME_MONITOR_LEFT=0
GAME_MONITOR_WIDTH=880
GAME_MONITOR_HEIGHT=500
CAPTURE_FPS=5
WIN_BADGE_GOLD_THRESHOLD=0.12
CAPTURE_COOLDOWN_SECONDS=4

# ===================== MODEL =====================
MODEL_WEIGHTS_PATH=./models/weights/best.pt
MODEL_CONFIDENCE=0.75
# auto | cpu | mps | cuda | cuda:0 | 0   (auto picks CUDA -> MPS -> CPU)
MODEL_DEVICE=auto

# ===================== TRAINING (model/) =====================
# Only needed to build a model. Free API key: https://app.roboflow.com (Settings -> API).
# Copy workspace/project/version from your dataset's "Download -> YOLOv8" snippet.
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_PROJECT=
ROBOFLOW_VERSION=1
BASE_MODEL=yolov8n.pt
TRAIN_EPOCHS=100
TRAIN_IMGSZ=640
TRAIN_BATCH=16
# DATA_YAML=./dataset/data.yaml   # override dataset config; otherwise auto-detected

# ===================== API PUSH (--live sends recognized rounds) =====================
# Where each recognized round is POSTed. Leave API_BASE_URL empty to disable
# sending (recognition still runs). For local testing: python tools/mock_api.py
API_BASE_URL=
API_RESULT_PATH=/baccarat/result
API_TIMEOUT_SECONDS=10
API_MAX_RETRIES=3
# Auth (optional): if API_JWT_SECRET is set, a short-lived JWT is signed per
# request; else if API_TOKEN is set, it's sent as a static Bearer; else no auth.
API_JWT_SECRET=          # use >= 32 chars; must match what your backend verifies
API_JWT_TTL_SECONDS=3600
API_TOKEN=

# ===================== RESULTS STORAGE =====================
# Every recognized round is appended as one JSON line to this file (independent
# of the API — results are stored even with no backend configured).
RESULTS_FILE=./logs/results.jsonl
RESULTS_ENABLED=true

# ===================== LOGGING =====================
LOG_LEVEL=INFO
# Leave LOG_FILE_PATH unset for console-only logging.
# LOG_FILE_PATH=./logs/app.log
LOG_ROTATION=50 MB
LOG_RETENTION=7 days
