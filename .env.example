# ===================== SCREEN CAPTURE =====================
GAME_MONITOR_TOP=0
GAME_MONITOR_LEFT=0
GAME_MONITOR_WIDTH=880
GAME_MONITOR_HEIGHT=500
CAPTURE_FPS=5
WIN_BADGE_GOLD_THRESHOLD=0.04
CAPTURE_COOLDOWN_SECONDS=4

# ROIs: x1,y1,x2,y2 in full-screen coordinates.
# These match the marked areas: player cards, banker cards, winner badge,
# player score, and banker score.
PLAYER_CARDS_ROI=340,780,850,997
BANKER_CARDS_ROI=1157,782,1643,992
WIN_BADGE_ROI=906,784,1103,927
PLAYER_SCORE_ROI=817,711,887,781
BANKER_SCORE_ROI=1129,716,1189,777

# ===================== MODEL =====================
MODEL_WEIGHTS_PATH=./models/weights/best.pt
MODEL_CONFIDENCE=0.10
MODEL_DEVICE=auto
OCR_ENABLED=false
SCORE_MODEL_WEIGHTS_PATH=./models/weights/score_digits.pt
SCORE_CLASSIFIER_ENABLED=true
SCORE_CLASSIFIER_MIN_CONF=0.80
SCORE_CLASSIFIER_IMGSZ=96
SCORE_THIRD_CARD_CORRECTION=false
SCORE_THIRD_CARD_MIN_CONF=0.98
CENTER_X_DUP_PX=55
ALLOW_SAME_CARD_DUPLICATES=true
CARD_DEBUG_DETECTIONS=false
CARD_LAYOUT_AWARE_PICK=true
CARD_FIXED_ZONE_PICK=true
CARD_PLAYER_THIRD_ZONE_END=0.38
CARD_BANKER_THIRD_ZONE_START=0.55
CARD_TOP_EDGE_RATIO=0.45
CARD_SIDEWAYS_MIN_CONF=0.18
CARD_MIN_UPRIGHT_CARDS=2
CARD_UPRIGHT_MIN_CENTER_GAP=25
FIX_SIDEWAYS_5D_AS_9D=false
SCORE_CARD_CORRECTION_MIN_CONF=0.80
SCORE_CARD_TRIM_ILLEGAL_THIRDS=false
SCORE_RULE_RECONCILE=false
SCORE_ZERO_VALUE_RANK=Q
SCORE_CARD_CORRECTION_OVERRIDES=player:9S:0=QS,banker:10C:3=3D
TRUST_DISPLAY_SCORE_BADGE=false
VALIDATION_IGNORE_BACCARAT_RULES=true
REQUIRE_VALIDATION_PASSED=false

# ===================== TRAINING =====================
ROBOFLOW_API_KEY=
ROBOFLOW_WORKSPACE=
ROBOFLOW_PROJECT=
ROBOFLOW_VERSION=1
KAGGLE_DATASET_SLUG=artemzysko/playing-cards-dataset-yolo-object-detection
BASE_MODEL=./models/weights/best.pt
TRAIN_EPOCHS=35
TRAIN_IMGSZ=512
TRAIN_BATCH=16
TRAIN_WORKERS=8
TRAIN_CACHE=true
TRAIN_PATIENCE=8
TRAIN_FREEZE=10
TRAIN_PLOTS=false
TRAIN_VERBOSE=true
TRAIN_RUN_NAME=cards_fast

# Score digit classifier training (0-9 score circles)
SCORE_DATA_DIR=./dataset/score_digits/classify
SCORE_BASE_MODEL=yolov8n-cls.pt
SCORE_TRAIN_EPOCHS=40
SCORE_TRAIN_IMGSZ=96
SCORE_TRAIN_BATCH=64
SCORE_TRAIN_WORKERS=4
SCORE_TRAIN_CACHE=true
SCORE_TRAIN_PATIENCE=8
SCORE_TRAIN_RUN_NAME=score_digits

# ===================== API PUSH =====================
API_BASE_URL=
API_RESULT_PATH=/baccarat/result
API_TIMEOUT_SECONDS=10
API_MAX_RETRIES=3
API_JWT_SECRET=
API_JWT_TTL_SECONDS=3600
API_TOKEN=

# ===================== CSE MANUAL REVIEW PUSH =====================
CSE_REVIEW_ENABLED=true
CSE_API_URL=http://154.19.187.190:3000/api/review-items/live
CSE_API_TOKEN=
CSE_API_TOKEN_HEADER=x-cse-api-token
CSE_FRAME_DIR=./logs/cse_frames
CSE_TIMEOUT_SECONDS=15
CSE_MAX_RETRIES=3
CSE_IMAGE_FIELD=image
CSE_AI_RESPONSE_FIELD=ai_response
CSE_SOURCE_FIELD=source
CSE_ROUND_ID_FIELD=round_id

# ===================== CSE FEEDBACK EXPORT =====================
AI_FEEDBACK_API_URL=http://154.19.187.190:3000/api/ai-feedback/cse-reviews
AI_FEEDBACK_API_TOKEN=

# ===================== RESULTS STORAGE =====================
RESULTS_FILE=./logs/results.jsonl
RESULTS_ENABLED=true

# ===================== LOGGING =====================
LOG_LEVEL=INFO
LOG_ROTATION=50 MB
LOG_RETENTION=7 days
